# Postgres
POSTGRES_USER=linkedin
POSTGRES_PASSWORD=linkedin
POSTGRES_DB=linkedin

# API (Go)
HTTP_ADDR=:8080
DATABASE_URL=postgres://linkedin:linkedin@postgres:5432/linkedin?sslmode=disable
MIGRATIONS_DIR=/migrations
SKIP_SQL_MIGRATIONS=0
INTERNAL_JOB_TOKEN=dev-internal-token
JWT_SECRET=dev-jwt-secret-change-in-production

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_KEY=linkedin:jobs

# CORS (frontend em ../frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=1

# Workers
WORKER_ROLE=all
OUTBOX_POLL_INTERVAL_SEC=2
BATCH_ENABLED=1

# Elasticsearch (fase 3+)
ELASTICSEARCH_URL=http://elasticsearch:9200

# Kafka (fase 7+ — opcional)
# KAFKA_BROKERS=kafka:9092
