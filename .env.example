# Postgres
POSTGRES_USER=linkedin
POSTGRES_PASSWORD=linkedin
POSTGRES_DB=linkedin

# API (Go)
HTTP_ADDR=:8080
DATABASE_URL=postgres://linkedin:linkedin@postgres:5432/linkedin?sslmode=disable
DATABASE_URL_LIVE=postgres://linkedin_live:linkedin_live@postgres-live:5432/linkedin_live?sslmode=disable
MIGRATIONS_DIR=/migrations
SKIP_SQL_MIGRATIONS=0
INTERNAL_JOB_TOKEN=dev-internal-token
JWT_SECRET=dev-jwt-secret-change-in-production

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_KEY=linkedin:jobs

# CORS (frontend em ../frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=1

# Workers — microservices (WORKER_ROLE per service)
WORKER_HEALTH_ENABLED=1
REDIS_QUEUE_REALTIME=linkedin:jobs:realtime
REDIS_QUEUE_INDEXER=linkedin:jobs:indexer
REDIS_QUEUE_GRAPH=linkedin:jobs:graph
OUTBOX_POLL_INTERVAL_SEC=2
BATCH_ENABLED=1

# Elasticsearch (fase 3+)
ELASTICSEARCH_URL=http://elasticsearch:9200

# Kafka (fase 7 — opcional, profile kafka)
# KAFKA_BROKERS=redpanda:9092
# KAFKA_TOPIC=linkedin.jobs

# Simulator (profile sim — docker compose --profile sim up worker-simulator)
# SIMULATOR_AGENT_COUNT=2000
# SIMULATOR_SEED=42
# SIMULATOR_PHASE=auto
# SIMULATOR_TICK_SEC=1
# SIMULATOR_BATCH_SIZE=50
# SIMULATOR_BOOTSTRAP_COMMIT_EVERY=100
# SIMULATOR_ENQUEUE_SEARCH=0
# SIMULATOR_METRICS_ENABLED=1
# SIMULATOR_METRICS_PORT=9100
# SIMULATOR_GLOBAL_POSTS_POOL=200
# SIMULATOR_TIMEZONE=America/Recife
# Volume lab (graph_only mode — static synthetic graph, no social steady loop)
# SIMULATOR_MODE=graph_only
# SIMULATOR_VOLUME_AGENT_COUNT=1000
# SIMULATOR_GRAPH_MEAN_DEGREE=80
# SIMULATOR_GRAPH_MIN_DEGREE=10
# SIMULATOR_GRAPH_MAX_DEGREE=300
# Profiles: sim-small (500), sim (2k), sim-large (10k)
# Validation: python scripts/simulator_validate.py [--plot]

# Observabilidade
METRICS_ENABLED=1

# LLM (realm live — e2e TestE2E_LLM_* e worker SIMULATOR_LLM=1)
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# SIMULATOR_LLM=1
# SIMULATOR_LLM_MAX_PER_MIN=12
# SIMULATOR_LLM_MAX_PER_DAY=800
